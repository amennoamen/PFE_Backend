// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  nom       String
  prenom    String
  role      Role       @default(COMPTABLE)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  lastLogin DateTime?
  
  // relation avec documents 
  documents Document[] // MANY 


  @@map("users")
}

enum Role {
  ADMIN
  MANAGER
  COMPTABLE
}

// Modéle Document 

model Document {
  id         String   @id @default(uuid())
  originalName    String
  fileName   String
  filePath   String
  fileType   String
  fileSize   Int
  
  statut     StatutDocument @default(EN_COURS)
  
  uploadedBy String
  user       User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade) // ONE user
  
 // relation 1 to 1 avec les donnee extraire 
  analyse      DocumentAnalyse?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@index([uploadedBy])
  @@index([statut])
  @@index([createdAt])
  
  @@map("documents")
}

enum StatutDocument {
  EN_COURS          
  TRAITEMENT        
  VALIDE            
  REJETE            
  ENVOYE_BC         
}

model DocumentAnalyse {
  id           String   @id @default(uuid())

  // relation 1-to-1 avec Document
  documentId   String   @unique
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  //  Classification
  typeDocument String?
  bcEntity     String?
  categorie    String?
  langue       String?
  pays         String?
  resume       String?

  // Données BC (JSON flexible)
  bcFields     Json?
  bcLines      Json?

  //  Scores 
  scoreOcr          Float?
  scoreClassification Float?
  scoreExtraction   Float?
  scoreGlobal       Float?

  //  Validation
  statutValidation  String?   // VALIDE, EN_ATTENTE
  actionRecommandee String?   // VALIDATION_AUTO, CORRECTION_MANUELLE...
  //champsManquants   String[]

  // OCR 
  texteExtrait  String?   @db.Text
  methodeOcr    String?   // pdfplumber ou doctr
  nbMots        Int?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("document_analyses")
}