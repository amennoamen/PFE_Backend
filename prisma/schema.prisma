// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  nom       String
  prenom    String
  role      Role       @default(COMPTABLE)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  lastLogin DateTime?
  
  // relation avec documents 
  documents Document[] // MANY 


  @@map("users")
}

enum Role {
  ADMIN
  MANAGER
  COMPTABLE
}

// Modéle Document 

model Document {
  id         String   @id @default(uuid())
  originalName    String
  fileName   String
  filePath   String
  fileType   String
  fileSize   Int
  
  statut     StatutDocument @default(EN_COURS)
  
  uploadedBy String
  user       User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade) // ONE user
  
 
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@index([uploadedBy])
  @@index([statut])
  @@index([createdAt])
  
  @@map("documents")
}

enum StatutDocument {
  EN_COURS          
  TRAITEMENT        
  VALIDE            
  REJETE            
  ENVOYE_BC         
}